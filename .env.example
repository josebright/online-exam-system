# Online Examination System - Environment Configuration
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME="Online Examination System"
APP_VERSION="1.0.0"
APP_ENV="development"

BASE_URL="http://localhost:8888/online-exam-system"
ADMIN_EMAIL="admin@examportal.com"

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST="localhost"
DB_PORT="8889"
DB_NAME="exam_system"
DB_USER="root"
DB_PASS="Ugum@du12"
DB_CHARSET="utf8mb4"

# ============================================
# SECURITY SETTINGS
# ============================================
SESSION_LIFETIME="3600"
MAX_LOGIN_ATTEMPTS="5"
LOGIN_TIMEOUT="900"
SESSION_COOKIE_SECURE="0"

# ============================================
# EXAM SETTINGS
# ============================================
MIN_EXAM_DURATION="5"
MAX_EXAM_DURATION="180"
AUTO_SAVE_INTERVAL="30"
TAB_SWITCH_WARNING_THRESHOLD="5"

# ============================================
# PAGINATION
# ============================================
ITEMS_PER_PAGE="10"

# ============================================
# ERROR REPORTING
# ============================================
ERROR_REPORTING="E_ALL"
DISPLAY_ERRORS="1"
LOG_ERRORS="1"
